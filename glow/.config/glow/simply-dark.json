{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "15"
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "italic": true,
    "color": "3"
  },
  "paragraph": {},
  "list": {
    "indent": 2,
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "bold": true
  },
  "h1": {
    "color": "12",
    "bold": true
  },
  "h2": {
    "color": "4",
    "bold": true
  },
  "h3": {
    "color": "6",
    "bold": true
  },
  "h4": {
    "color": "8"
  },
  "h5": {
    "color": "8"
  },
  "h6": {
    "color": "8",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true,
    "color": "3"
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "8",
    "format": "\n────────\n"
  },
  "item": {
    "block_prefix": "• ",
    "color": "13"
  },
  "enumeration": {
    "block_prefix": ". ",
    "color": "4"
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "14",
    "underline": true
  },
  "link_text": {
    "color": "14"
  },
  "image": {
    "color": "14",
    "underline": true
  },
  "image_text": {
    "color": "14"
  },
  "code": {
    "color": "10"
  },
  "code_block": {
    "margin": 1,
    "chroma": {
      "text": {
        "color": "15"
      },
      "error": {
        "color": "15",
        "background_color": "1"
      },
      "comment": {
        "color": "8",
        "italic": true
      },
      "comment_preproc": {
        "color": "11"
      },
      "keyword": {
        "color": "13",
        "bold": true
      },
      "keyword_reserved": {
        "color": "13",
        "bold": true
      },
      "keyword_namespace": {
        "color": "9"
      },
      "keyword_type": {
        "color": "12"
      },
      "operator": {
        "color": "13"
      },
      "punctuation": {
        "color": "15"
      },
      "name": {
        "color": "15"
      },
      "name_builtin": {
        "color": "14"
      },
      "name_tag": {
        "color": "12"
      },
      "name_attribute": {
        "color": "4"
      },
      "name_class": {
        "color": "12",
        "bold": true
      },
      "name_constant": {
        "color": "13"
      },
      "name_decorator": {
        "color": "11"
      },
      "name_exception": {
        "color": "9"
      },
      "name_function": {
        "color": "14"
      },
      "name_other": {},
      "literal": {},
      "literal_number": {
        "color": "11"
      },
      "literal_date": {},
      "literal_string": {
        "color": "3"
      },
      "literal_string_escape": {
        "color": "10"
      },
      "generic_deleted": {
        "color": "9"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "10"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "8"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n→ "
  },
  "html_block": {},
  "html_span": {}
}
