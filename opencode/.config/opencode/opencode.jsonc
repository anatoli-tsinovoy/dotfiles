{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openai/gpt-5.4-mini",
  "share": "disabled",
  "plugin": [],
  "disabled_providers": [
    "opencode",
    "amazon-bedrock" // Disabled because opencode defaults to trying to use AWS SSO credentials to access Bedrock
  ],
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"]
    },
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    }
  },
  "formatter": {
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": [".py", ".pyi"]
    },
    "ruff_organize_imports": {
      "command": ["ruff", "check", "--select", "I", "--fix-only", "$FILE"],
      "extensions": [".py", ".pyi"]
    }
  },
}
